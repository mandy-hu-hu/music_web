<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music Web</title>
    <link rel="stylesheet" href="style.css">
</head>

<body class="main-page">
    <header>
        <h2 class="logo">Music Web</h2>
        <nav class="navigation">
            <a href="#">Home</a>
            <a href="#" id="btnLogout">Logout</a>
        </nav>
    </header>

    <main class="dashboard">

        <!-- User Area -->
        <section class="area user-area">
            <h3>User</h3>
            <div class="user-info">
                <ion-icon name="person-circle" class="user-avatar"></ion-icon>
                <p class="user-name" id="displayUsername"></p>
                <p class="user-email" id="displayEmail"></p>
            </div>
        </section>

        <!-- Subscription Area -->
        <section class="area subscription-area">
            <h3>My Subscriptions</h3>
            <div id="subscriptionList" class="subscription-list">
                <p class="empty-msg">No subscriptions yet.</p>
            </div>
        </section>

        <!-- Query Area -->
        <section class="area query-area">
            <h3>Query</h3>
            <form id="queryForm" class="query-form">
                <div class="query-fields">
                    <div class="query-field">
                        <label for="qTitle">Title</label>
                        <input id="qTitle" type="text" autocomplete="off">
                    </div>
                    <div class="query-field">
                        <label for="qYear">Year</label>
                        <input id="qYear" type="text" autocomplete="off">
                    </div>
                    <div class="query-field">
                        <label for="qArtist">Artist</label>
                        <input id="qArtist" type="text" autocomplete="off">
                    </div>
                    <div class="query-field">
                        <label for="qAlbum">Album</label>
                        <input id="qAlbum" type="text" autocomplete="off">
                    </div>
                </div>
                <p id="queryError" class="query-error"></p>
                <button type="submit" class="btn query-btn">Query</button>
            </form>
            <div id="queryResults" class="query-results"></div>
        </section>

    </main>

    <script>
        const email = sessionStorage.getItem("loggedInEmail");
        const username = sessionStorage.getItem("loggedInUsername");
        if (!email) {
            globalThis.location.replace("index.html");
        }

        document.getElementById("displayUsername").textContent = username || email;
        document.getElementById("displayEmail").textContent = email;

        document.getElementById("btnLogout").addEventListener("click", (e) => {
            e.preventDefault();
            sessionStorage.removeItem("loggedInEmail");
            sessionStorage.removeItem("loggedInUsername");
            globalThis.location.href = "index.html?showLogin=true";
        });

        const subKey = "subscriptions_" + email;

        function getSubscriptions() {
            return JSON.parse(localStorage.getItem(subKey) || "[]");
        }

        function saveSubscriptions(subs) {
            localStorage.setItem(subKey, JSON.stringify(subs));
        }

        function makeSongCard(song, actionLabel, onAction) {
            const card = document.createElement("div");
            card.className = "song-card";

            const img = document.createElement("img");
            img.src = song.img_url;
            img.alt = song.artist;
            img.className = "song-img";

            const info = document.createElement("div");
            info.className = "song-info";

            const titleEl = document.createElement("span");
            titleEl.className = "song-title";
            titleEl.textContent = song.title;

            const artistEl = document.createElement("span");
            artistEl.className = "song-artist";
            artistEl.textContent = song.artist;

            const albumEl = document.createElement("span");
            albumEl.className = "song-album";
            albumEl.textContent = song.album + " (" + song.year + ")";

            info.append(titleEl, artistEl, albumEl);

            const btn = document.createElement("button");
            btn.className = actionLabel === "Remove" ? "btn-remove" : "btn-add";
            btn.textContent = actionLabel;
            btn.addEventListener("click", onAction);

            card.append(img, info, btn);
            return card;
        }

        function renderSubscriptions() {
            const list = document.getElementById("subscriptionList");
            const subs = getSubscriptions();
            list.innerHTML = "";

            if (subs.length === 0) {
                const msg = document.createElement("p");
                msg.className = "empty-msg";
                msg.textContent = "No subscriptions yet.";
                list.appendChild(msg);
                return;
            }

            subs.forEach((song, i) => {
                const card = makeSongCard(song, "Remove", () => {
                    const current = getSubscriptions();
                    current.splice(i, 1);
                    saveSubscriptions(current);
                    renderSubscriptions();
                });
                list.appendChild(card);
            });
        }

        renderSubscriptions();

        let allSongs = [];

        document.getElementById("queryForm").addEventListener("submit", (e) => {
            e.preventDefault();

            const qTitle  = document.getElementById("qTitle").value.trim().toLowerCase();
            const qYear   = document.getElementById("qYear").value.trim();
            const qArtist = document.getElementById("qArtist").value.trim().toLowerCase();
            const qAlbum  = document.getElementById("qAlbum").value.trim().toLowerCase();
            const errorEl = document.getElementById("queryError");
            const resultsDiv = document.getElementById("queryResults");

            resultsDiv.innerHTML = "";
            errorEl.textContent = "";

            if (!qTitle && !qYear && !qArtist && !qAlbum) {
                errorEl.textContent = "Please fill in at least one field.";
                return;
            }

            const matches = allSongs.filter(s =>
                (!qTitle  || s.title.toLowerCase().includes(qTitle))  &&
                (!qYear   || s.year === qYear)                         &&
                (!qArtist || s.artist.toLowerCase().includes(qArtist)) &&
                (!qAlbum  || s.album.toLowerCase().includes(qAlbum))
            );

            if (matches.length === 0) {
                const msg = document.createElement("p");
                msg.className = "empty-msg";
                msg.textContent = "No result is retrieved. Please query again.";
                resultsDiv.appendChild(msg);
                return;
            }

            matches.forEach(song => {
                const subs = getSubscriptions();
                const already = subs.some(s =>
                    s.title === song.title && s.artist === song.artist && s.album === song.album
                );
                const card = makeSongCard(song, already ? "✓ Subscribed" : "Subscribe", function () {
                    const current = getSubscriptions();
                    const exists = current.some(s =>
                        s.title === song.title && s.artist === song.artist && s.album === song.album
                    );
                    if (!exists) {
                        current.push(song);
                        saveSubscriptions(current);
                        renderSubscriptions();
                        this.textContent = "✓ Subscribed";
                        this.disabled = true;
                    }
                });
                if (already) {
                    card.querySelector(".btn-add").disabled = true;
                }
                resultsDiv.appendChild(card);
            });
        });
    </script>

    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>
</body>

</html>
